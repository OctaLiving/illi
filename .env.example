# Copy to .env and fill in. Do not commit real secrets.

# Database — Postgres (via @prisma/adapter-pg). Use a pooled connection string for
# the app (e.g. Prisma Postgres `pooled.db.prisma.io`); a direct URL is only needed
# if your host's pooler can't run migrations.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Better Auth — generate a unique 32+ char secret per environment.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# NOWPayments — set the API key to switch from the simulated provider to live
# crypto checkout. IPN secret comes from the NOWPayments dashboard.
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_PAY_CURRENCY="usdttrc20"

# SMTP — leave SMTP_HOST blank to log emails to the console instead of sending.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="illi <hello@illi.example>"

# Days an unpaid renewal stays past_due before the subscription is canceled.
RENEWAL_GRACE_DAYS="3"
